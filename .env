# Notion 域名, 可配置为反向代理
# NEXT_PUBLIC_NOTION_HOST=https://www.notion.so

# -------------------
# notion.config.js (Notion 扩展配置)
# -------------------

# Notion 数据库视图索引 (从0开始)
# 用于站点数据和排序的视图。-1 代表最后一个视图。
# 默认值: 0
# NEXT_PUBLIC_NOTION_INDEX=0

# 自定义 Notion 数据库字段名
# NEXT_PUBLIC_NOTION_PROPERTY_PASSWORD=password
# NEXT_PUBLIC_NOTION_PROPERTY_TYPE=type
# NEXT_PUBLIC_NOTION_PROPERTY_TYPE_POST=Post
# NEXT_PUBLIC_NOTION_PROPERTY_TYPE_PAGE=Page
# NEXT_PUBLIC_NOTION_PROPERTY_TYPE_NOTICE=Notice
# NEXT_PUBLIC_NOTION_PROPERTY_TYPE_MENU=Menu
# NEXT_PUBLIC_NOTION_PROPERTY_TYPE_SUB_MENU=SubMenu
# NEXT_PUBLIC_NOTION_PROPERTY_TITLE=title
# NEXT_PUBLIC_NOTION_PROPERTY_STATUS=status
# NEXT_PUBLIC_NOTION_PROPERTY_STATUS_PUBLISH=Published
# NEXT_PUBLIC_NOTION_PROPERTY_STATUS_INVISIBLE=Invisible
# NEXT_PUBLIC_NOTION_PROPERTY_SUMMARY=summary
# NEXT_PUBLIC_NOTION_PROPERTY_SLUG=slug
# NEXT_PUBLIC_NOTION_PROPERTY_CATEGORY=category
# NEXT_PUBLIC_NOTION_PROPERTY_DATE=date
# NEXT_PUBLIC_NOTION_PROPERTY_TAGS=tags
# NEXT_PUBLIC_NOTION_PROPERTY_ICON=icon
# NEXT_PUBLIC_NOTION_PROPERTY_EXT=ext

# -------------------
# performance.config.js (性能优化配置)
# -------------------

# 预加载关键资源
# NEXT_PUBLIC_PRELOAD_CRITICAL_RESOURCES=true

# 图片懒加载
# NEXT_PUBLIC_LAZY_LOAD_IMAGES=true
# NEXT_PUBLIC_LAZY_LOAD_THRESHOLD='200px'

# 代码分割
# NEXT_PUBLIC_ENABLE_CODE_SPLITTING=true
# NEXT_PUBLIC_CHUNK_SIZE_LIMIT=244000

# 缓存 TTL (秒)
# NEXT_PUBLIC_BROWSER_CACHE_TTL=86400 # 浏览器缓存
# NEXT_PUBLIC_CDN_CACHE_TTL=604800 # CDN 缓存

# 压缩
# NEXT_PUBLIC_ENABLE_GZIP=true
# NEXT_PUBLIC_ENABLE_BROTLI=true

# 延迟加载第三方脚本
# NEXT_PUBLIC_DEFER_THIRD_PARTY_SCRIPTS=true

# 图片格式优化
# NEXT_PUBLIC_WEBP_SUPPORT=true
# NEXT_PUBLIC_AVIF_SUPPORT=true

# 预取链接和图片
# NEXT_PUBLIC_PREFETCH_LINKS=true
# NEXT_PUBLIC_PREFETCH_IMAGES=false

# Web Vitals 报告
# NEXT_PUBLIC_ENABLE_WEB_VITALS=true

