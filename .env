# NEXT_PUBLIC_UMAMI_ID=

# SEO 网站验证
# NEXT_PUBLIC_SEO_GOOGLE_SITE_VERIFICATION= # 谷歌网站验证代码
# NEXT_PUBLIC_SEO_BAIDU_SITE_VERIFICATION= # 百度网站验证代码

# -------------------
# animation.config.js (动画效果配置)
# -------------------

# 鼠标点击烟花特效
NEXT_PUBLIC_FIREWORKS=false

# 鼠标跟随特效
NEXT_PUBLIC_MOUSE_FOLLOW=false

# 樱花飘落特效
NEXT_PUBLIC_SAKURA=false

# 漂浮线条特效
NEXT_PUBLIC_NEST=false

# 动态彩带特效
NEXT_PUBLIC_FLUTTERINGRIBBON=false

# 静态彩带特效
NEXT_PUBLIC_RIBBON=false

# 星空特效 (仅在夜间模式生效)
NEXT_PUBLIC_STARRY_SKY=false

# Animate.css 动画库 CDN URL
# NEXT_PUBLIC_ANIMATE_CSS_URL=

# -------------------
# code.config.js (代码块配置)
# -------------------

# Prism.js 代码块主题
# 主题列表: https://github.com/PrismJS/prism-themes
# 默认主题
# NEXT_PUBLIC_PRISM_THEME_PREFIX_PATH=
# 是否开启主题切换
NEXT_PUBLIC_PRISM_THEME_SWITCH=true
# 浅色模式主题
# NEXT_PUBLIC_PRISM_THEME_LIGHT_PATH=
# 深色模式主题
# NEXT_PUBLIC_PRISM_THEME_DARK_PATH=

# Mac 风格代码块窗口按钮
# NEXT_PUBLIC_CODE_MAC_BAR=true

# 显示行号
NEXT_PUBLIC_CODE_LINE_NUMBERS=true

# 代码块折叠
NEXT_PUBLIC_CODE_COLLAPSE=true
# 默认展开
NEXT_PUBLIC_CODE_COLLAPSE_EXPAND_DEFAULT=true

# Mermaid.js 图表库 CDN URL
# NEXT_PUBLIC_MERMAID_CDN=

