# NotionNext 环境变量
# 以下是 NotionNext 项目所需的环境变量配置。
# 更多细节请参考官方文档：https://docs.tangly1024.com/

# -------------------
# blog.config.js (博客核心配置)
# -------------------

# Notion 页面 ID (必须)
# 这是您的博客内容来源的 Notion 数据库页面ID。
# 示例: NOTION_PAGE_ID=02ab3b8678004aa69e9e415905ef32a5,en:7c1d570661754c8fbc568e00a01fd70e
NOTION_PAGE_ID=2f34c7eecc23814e92d2e83c747fc88d

# Notion Access Token (可选, 用于私有数据库)
# 如果您的 Notion 数据库不是公开的，则需要提供 NOTION_TOKEN_V2。
# 请参考文档了解如何获取此令牌。
# NOTION_TOKEN_V2=

# Notion Active User (可选)
# 如果您的 Notion 工作区中有多个用户，您可以在此指定用于API请求的用户。
# NOTION_ACTIVE_USER=

# API 基础URL (可选)
# Notion API 的默认请求地址。如果您使用了反向代理，可以在此自定义。
# 默认值: https://www.notion.so/api/v3
# API_BASE_URL=

# 博客主题
# 定义您博客的主题。支持的主题可以在 /themes 目录下找到。
# 示例: NEXT_PUBLIC_THEME=simple
NEXT_PUBLIC_THEME=heo

# 博客语言
# 您博客的主要语言。
# 示例: NEXT_PUBLIC_LANG=en-US
# NEXT_PUBLIC_LANG=zh-CN

# 博客建立年份
# 如果留空，将使用当前年份。
# 示例: NEXT_PUBLIC_SINCE=2021
NEXT_PUBLIC_SINCE=1974

# 伪静态路径
# 如果设置为 true，所有文章的URL将以 .html 结尾。
# 示例: NEXT_PUBLIC_PSEUDO_STATIC=false
NEXT_PUBLIC_PSEUDO_STATIC=true

# 缓存更新间隔 (秒)
# Next.js 在后台重新生成静态页面的频率。
# 默认值: 60
# NEXT_REVALIDATE_SECOND=60

# 默认外观
# 网站默认外观模式: 'light' (日间), 'dark' (夜间), or 'auto' (自动)。
# 示例: NEXT_PUBLIC_APPEARANCE=light
NEXT_PUBLIC_APPEARANCE=auto

# 自动夜间模式时间范围
# 在此时间范围内（24小时制），将自动启用夜间模式。
# 示例: NEXT_PUBLIC_APPEARANCE_DARK_TIME=18,6
NEXT_PUBLIC_APPEARANCE_DARK_TIME=21,8

# 您的昵称 例如 tangly1024
NEXT_PUBLIC_AUTHOR="李狗蛋"
# 作者简介
NEXT_PUBLIC_BIO="屎上的第一人👍"
# 网站地址
NEXT_PUBLIC_LINK=https://blog.zima.dpdns.org
# 网站关键词
NEXT_PUBLIC_KEYWORD=LiGod’s Blog

# 网站图标 (Favicon)
# 指向您博客图标的路径或URL。
# 示例: NEXT_PUBLIC_FAVICON=/favicon.ico
NEXT_PUBLIC_FAVICON=https://pic.blog.zima.dpdns.org/file/1775227723984_5c61be7d1ab58977.gif

# 备案信息 (中国大陆地区)
# BEI_AN= # ICP备案号
# BEI_AN_LINK= # 备案链接
# BEI_AN_GONGAN= # 公安备案号

# RSS 订阅
# 启用或禁用博客的RSS订阅功能。
# 示例: NEXT_PUBLIC_ENABLE_RSS=true
NEXT_PUBLIC_ENABLE_RSS=false

# 自定义菜单
# 启用后，您可以使用 Notion 中类型为 'Menu' 的页面来创建导航菜单。
# 示例: NEXT_PUBLIC_CUSTOM_MENU=true
# NEXT_PUBLIC_CUSTOM_MENU=true

# 页面内容复制
# 如果设置为 false，用户将无法复制您网站上的内容。
# 示例: NEXT_PUBLIC_CAN_COPY=true
# NEXT_PUBLIC_CAN_COPY=true

# 侧边栏布局反转
# 在支持的主题中，反转侧边栏的位置 (左<->右)。
# 示例: NEXT_PUBLIC_LAYOUT_SIDEBAR_REVERSE=false
# NEXT_PUBLIC_LAYOUT_SIDEBAR_REVERSE=false

# 欢迎语
# 为支持打字机效果的主题设置欢迎语，多个欢迎语请用英文逗号隔开。
NEXT_PUBLIC_GREETING_WORDS="🐥, 🤡,胎,煤,🎉 🐥🤡胎煤 🎉"

# UUID 到 Slug 重定向
# 将旧的基于 UUID 的 URL 重定向到新的基于 Slug 的 URL。
# 示例: UUID_REDIRECT=false
# UUID_REDIRECT=false

# -------------------
# ad.config.js (广告配置)
# -------------------

# 谷歌广告联盟 (Google AdSense)
# NEXT_PUBLIC_ADSENSE_GOOGLE_ID= # 您的谷歌广告ID, e.g., ca-pub-xxxxxxxxxxxxxxxx
# NEXT_PUBLIC_ADSENSE_GOOGLE_TEST=false # 是否开启测试模式
# NEXT_PUBLIC_ADSENSE_GOOGLE_SLOT_IN_ARTICLE= # 文章内嵌广告单元ID
# NEXT_PUBLIC_ADSENSE_GOOGLE_SLOT_FLOW= # 信息流广告单元ID
# NEXT_PUBLIC_ADSENSE_GOOGLE_SLOT_NATIVE= # 原生广告单元ID
# NEXT_PUBLIC_ADSENSE_GOOGLE_SLOT_AUTO= # 自动广告单元ID

# 万维广告 (WWAds)
# 面向中文开发者的广告网络. https://wwads.cn/
# NEXT_PUBLIC_WWAD_ID= # 您的万维广告ID
# NEXT_PUBLIC_WWADS_AD_BLOCK_DETECT=false # 是否开启广告屏蔽检测

